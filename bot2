name: Albo Pretorio Bot

on:
  schedule:
    # Ogni ora, dalle 7:00 alle 22:00 ora italiana (UTC+2 in estate)
    - cron: '0 5-20 * * *'
  workflow_dispatch:  # Permette avvio manuale dal sito GitHub

jobs:
  run-bot:
    runs-on: ubuntu-latest

    steps:
      - name: Scarica il codice
        uses: actions/checkout@v4

      - name: Installa Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Installa dipendenze
        run: pip install requests beautifulsoup4

      - name: Carica file atti già visti (cache)
        uses: actions/cache@v4
        with:
          path: seen_atti.json
          key: seen-atti-${{ github.run_id }}
          restore-keys: |
            seen-atti-

      - name: Esegui il bot
        env:
          TELEGRAM_TOKEN:    ${{ secrets.TELEGRAM_TOKEN }}
          TELEGRAM_CHAT_ID:  ${{ secrets.TELEGRAM_CHAT_ID }}
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
        run: python bot.py
